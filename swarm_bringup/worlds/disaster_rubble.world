    <!-- 幸存者模型 (生命探测目标) 位于废墟旁 -->
    <model name="survivor_01"><static>true</static>
      <pose>3.0 4.5 0.02 0 0 0</pose>
      <link name="body">
        <visual name="v">
          <geometry><cylinder><radius>0.15</radius><length>0.60</length></cylinder></geometry>
          <material><diffuse>0.85 0.25 0.10 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><cylinder><radius>0.15</radius><length>0.60</length></cylinder></geometry>
        </collision>
      </link>
      <link name="head">
        <pose>0 0 0.38 0 0 0</pose>
        <visual name="v">
          <geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><diffuse>0.90 0.75 0.65 1</diffuse></material>
        </visual>
      </link>
      <joint name="head_joint" type="fixed">
        <parent>body</parent><child>head</child>
      </joint>

<?xml version="1.0"?>
<sdf version="1.6">
  <world name="disaster_rubble">
    <gravity>0 0 -9.81</gravity>

    <!-- 昏暗应急照明 -->
    <scene>
      <ambient>0.18 0.18 0.22 1.0</ambient>
      <background>0.05 0.05 0.08 1.0</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 15 0.5 -0.3 0</pose>
      <diffuse>0.4 0.38 0.35 1.0</diffuse>
      <specular>0.1 0.1 0.1 1.0</specular>
      <direction>-0.5 0.3 -1.0</direction>
    </light>

    <!-- 地面: 暗色废墟纹理 -->
    <model name="ground">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>25 25</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>25 25</size></plane></geometry>
          <material>
            <ambient>0.08 0.07 0.07 1</ambient>
            <diffuse>0.15 0.14 0.14 1</diffuse>
            <specular>0.01 0.01 0.01 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 边界围墙 -->
    <model name="wall_north"><static>true</static>
      <pose>0 10 0.15 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>20 0.15 0.30</size></box></geometry>
          <material><diffuse>0.25 0.22 0.20 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>20 0.15 0.30</size></box></geometry></collision>
      </link>
    </model>
    <model name="wall_south"><static>true</static>
      <pose>0 -10 0.15 0 0 0</pose>

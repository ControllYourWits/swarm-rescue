<?xml version="1.0"?>
<!--
  rescue_robot.urdf.xacro — 三机统一 URDF (模块化版)

  通过 robot_name 参数切换机器人类型:
    xacro rescue_robot.urdf.xacro robot_name:=scout

  架构: 使用 common/ 共用模块, 与 scout/carrier/specialist.xacro 一致
  网格: linorobot2 chassis.dae + tire.dae (坐标系正确)
  兼容: RViz2 (robot_state_publisher) + Gazebo (spawn_entity)
-->
<robot name="rescue_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ═══ 参数 ═══ -->
  <xacro:arg name="robot_name" default="scout"/>
  <xacro:arg name="robot_color" default="0.18 0.42 0.82 1"/>

  <!-- ═══ 共用模块 ═══ -->
  <xacro:include filename="$(find swarm_bringup)/urdf/common/common_properties.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/chassis.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/mecanum_wheel.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/sensors.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/gazebo_plugins.xacro"/>

  <!-- ═══ 尺寸参数 (按机器人类型切换) ═══ -->
  <xacro:property name="CL" value="${0.55 if robot_name == 'carrier' else (0.45 if robot_name == 'specialist' else 0.42)}"/>
  <xacro:property name="CW" value="${0.40 if robot_name == 'carrier' else (0.35 if robot_name == 'specialist' else 0.32)}"/>
  <xacro:property name="CH" value="${0.129}"/>
  <xacro:property name="WR" value="${0.065 if robot_name == 'carrier' else (0.055 if robot_name == 'specialist' else 0.048)}"/>
  <xacro:property name="WW" value="${0.035 if robot_name == 'carrier' else (0.030 if robot_name == 'specialist' else 0.028)}"/>
  <xacro:property name="M"  value="${12.0 if robot_name == 'carrier' else (8.0 if robot_name == 'specialist' else 6.5)}"/>
  <xacro:property name="BX" value="${0.185 if robot_name == 'carrier' else (0.150 if robot_name == 'specialist' else 0.160)}"/>
  <xacro:property name="BY" value="${0.170 if robot_name == 'carrier' else (0.150 if robot_name == 'specialist' else 0.140)}"/>
  <xacro:property name="WZ" value="${-0.048 if robot_name == 'carrier' else (-0.044 if robot_name == 'specialist' else -0.040)}"/>

  <!-- Gazebo 颜色 -->
  <xacro:property name="GR" value="${0.15 if robot_name == 'carrier' else (0.92 if robot_name == 'specialist' else 0.18)}"/>
  <xacro:property name="GG" value="${0.75 if robot_name == 'carrier' else (0.52 if robot_name == 'specialist' else 0.42)}"/>
  <xacro:property name="GB" value="${0.30 if robot_name == 'carrier' else (0.12 if robot_name == 'specialist' else 0.82)}"/>

  <!-- ═══ 底盘 ═══ -->
  <xacro:chassis
    length="${CL}" width="${CW}" height="${CH}" mass="${M}"
    wheel_radius="${WR}" wheel_pos_z="${WZ}"
    mesh_file="package://swarm_bringup/meshes/shared/chassis.dae"
    body_material="body_blue" gazebo_r="${GR}" gazebo_g="${GG}" gazebo_b="${GB}"/>

  <!-- ═══ 麦轮 ═══ -->
  <xacro:mecanum_wheel side="front_left"  radius="${WR}" width="${WW}"
    pos_x="${BX}"  pos_y="${BY}"  pos_z="${WZ}" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="front_right" radius="${WR}" width="${WW}"
    pos_x="${BX}"  pos_y="${-BY}" pos_z="${WZ}" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_left"   radius="${WR}" width="${WW}"
    pos_x="${-BX}" pos_y="${BY}"  pos_z="${WZ}" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_right"  radius="${WR}" width="${WW}"
    pos_x="${-BX}" pos_y="${-BY}" pos_z="${WZ}" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>

  <!-- ═══ Scout 专属传感器 ═══ -->
  <xacro:if value="${robot_name == 'scout'}">
    <xacro:lidar_2d x="0.06" y="0" z="0.20"/>
    <xacro:lidar_3d x="0.06" y="0" z="0.16"/>
    <xacro:depth_camera x="0.21" y="0" z="0.10"/>
    <xacro:radar_mmw x="0.20" y="0" z="0.07"/>
    <xacro:imu_sensor/>
    <xacro:uwb_tag x="-0.10" y="0" z="0.14"/>
    <!-- laser_link (TF) -->
    <link name="laser_link"/>
    <joint name="laser_joint" type="fixed">
      <parent link="lidar_link"/><child link="laser_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:if>

  <!-- ═══ Carrier 专属 ═══ -->
  <xacro:if value="${robot_name == 'carrier'}">
    <xacro:supply_bay/>
    <xacro:router_antenna/>
    <xacro:imu_sensor/>
    <xacro:uwb_tag x="-0.15" y="0" z="0.14"/>
  </xacro:if>

  <!-- ═══ Specialist 专属 ═══ -->
  <xacro:if value="${robot_name == 'specialist'}">
    <xacro:thermal_camera x="0.20" y="-0.05" z="0.08"/>
    <xacro:robot_arm/>
    <xacro:led_bar x="0.20" y="0" z="0.08"/>
    <xacro:imu_sensor/>
    <xacro:uwb_tag x="-0.12" y="0" z="0.14"/>
  </xacro:if>

  <!-- ═══ Gazebo 插件 (麦轮+LiDAR+IMU) ═══ -->
  <xacro:gazebo_mecanum namespace="${robot_name}"
    wheel_base="${BX * 2}" wheel_separation="${BY * 2}" wheel_radius="${WR}"/>
</robot>

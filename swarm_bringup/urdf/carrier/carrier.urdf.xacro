<?xml version="1.0"?>
<!--
  carrier.urdf.xacro — Carrier 补给运输机

  特色: 4 槽位物资舱 + 4G 路由器 + 天线
  尺寸: 550×400mm, 12kg
-->
<robot name="carrier" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find swarm_bringup)/urdf/common/common_properties.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/chassis.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/mecanum_wheel.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/sensors.xacro"/>

  <!-- 底盘 (更大) -->
  <xacro:chassis length="0.55" width="0.40" height="0.129" mass="12.0"
    wheel_radius="0.065" wheel_pos_z="-0.048"
    mesh_file="package://swarm_bringup/meshes/shared/chassis.dae"
    body_material="body_green" gazebo_r="0.15" gazebo_g="0.75" gazebo_b="0.30"/>

  <!-- 麦轮 -->
  <xacro:mecanum_wheel side="front_left"  radius="0.065" width="0.035"
    pos_x="0.185" pos_y="0.170" pos_z="-0.048" mass="0.25"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="front_right" radius="0.065" width="0.035"
    pos_x="0.185" pos_y="-0.170" pos_z="-0.048" mass="0.25"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_left"   radius="0.065" width="0.035"
    pos_x="-0.185" pos_y="0.170" pos_z="-0.048" mass="0.25"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_right"  radius="0.065" width="0.035"
    pos_x="-0.185" pos_y="-0.170" pos_z="-0.048" mass="0.25"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>

  <!-- Carrier 专属 -->
  <xacro:supply_bay/>
  <xacro:router_antenna/>
  <xacro:uwb_tag x="-0.15" y="0" z="0.14"/>

  <!-- Gazebo -->
  <xacro:include filename="$(find swarm_bringup)/urdf/common/gazebo_plugins.xacro"/>
  <xacro:gazebo_mecanum namespace="carrier"
    wheel_base="0.370" wheel_separation="0.340" wheel_radius="0.065"/>
</robot>

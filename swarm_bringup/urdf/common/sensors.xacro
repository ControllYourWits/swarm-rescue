<?xml version="1.0"?>
<!--
  sensors.xacro — 传感器宏定义 (简化版, 字符串参数)

  所有传感器用 xyz 和 rpy 字符串参数定位
-->
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- 2D LiDAR -->
  <xacro:macro name="lidar_2d" params="x y z">
    <link name="lidar_link">
      <visual><geometry><cylinder radius="0.038" length="0.025"/></geometry><material name="dark"/></visual>
      <collision><geometry><cylinder radius="0.038" length="0.025"/></geometry></collision>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent link="base_link"/><child link="lidar_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 3D LiDAR (Livox) -->
  <xacro:macro name="lidar_3d" params="x y z">
    <link name="livox_link">
      <visual><geometry><box size="0.065 0.065 0.052"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.065 0.065 0.052"/></geometry></collision>
    </link>
    <joint name="livox_joint" type="fixed">
      <parent link="base_link"/><child link="livox_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 -0.262 0"/>
    </joint>
  </xacro:macro>

  <!-- 深度相机 -->
  <xacro:macro name="depth_camera" params="x y z">
    <link name="realsense_link">
      <visual><geometry><box size="0.124 0.026 0.029"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.124 0.026 0.029"/></geometry></collision>
    </link>
    <joint name="realsense_joint" type="fixed">
      <parent link="base_link"/><child link="realsense_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 -0.262 0"/>
    </joint>
  </xacro:macro>

  <!-- 毫米波雷达 -->
  <xacro:macro name="radar_mmw" params="x y z">
    <link name="radar_link">
      <visual><geometry><box size="0.065 0.045 0.012"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.065 0.045 0.012"/></geometry></collision>
    </link>
    <joint name="radar_joint" type="fixed">
      <parent link="base_link"/><child link="radar_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- IMU -->
  <xacro:macro name="imu_sensor">
    <link name="imu_link"/>
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/><child link="imu_link"/>
      <origin xyz="0.04 0 0.06" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- UWB -->
  <xacro:macro name="uwb_tag" params="x y z">
    <link name="uwb_tag">
      <visual><geometry><box size="0.025 0.025 0.008"/></geometry><material name="accent"/></visual>
    </link>
    <joint name="uwb_tag_j" type="fixed">
      <parent link="base_link"/><child link="uwb_tag"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 热成像 -->
  <xacro:macro name="thermal_camera" params="x y z">
    <link name="thermal_link">
      <visual><geometry><box size="0.035 0.035 0.025"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.035 0.035 0.025"/></geometry></collision>
    </link>
    <joint name="thermal_joint" type="fixed">
      <parent link="base_link"/><child link="thermal_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 机械臂 -->
  <xacro:macro name="robot_arm">
    <link name="arm_base">
      <visual><geometry><cylinder radius="0.035" length="0.015"/></geometry><material name="dark"/></visual>
      <collision><geometry><cylinder radius="0.035" length="0.015"/></geometry></collision>
    </link>
    <joint name="arm_base_j" type="fixed">
      <parent link="base_link"/><child link="arm_base"/>
      <origin xyz="-0.10 0 0.08" rpy="0 0 0"/>
    </joint>
    <link name="arm_link1">
      <visual><geometry><box size="0.035 0.035 0.15"/></geometry><material name="arm_color"/></visual>
      <collision><geometry><box size="0.035 0.035 0.15"/></geometry></collision>
      <inertial><origin xyz="0 0 0.075"/><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0002"/></inertial>
    </link>
    <joint name="arm_j1" type="revolute">
      <parent link="arm_base"/><child link="arm_link1"/>
      <origin xyz="0 0 0.022" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="3.0"/>
    </joint>
    <link name="arm_link2">
      <visual><geometry><box size="0.028 0.028 0.12"/></geometry><material name="arm_color"/></visual>
      <collision><geometry><box size="0.028 0.028 0.12"/></geometry></collision>
      <inertial><origin xyz="0 0 0.06"/><mass value="0.35"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0001"/></inertial>
    </link>
    <joint name="arm_j2" type="revolute">
      <parent link="arm_link1"/><child link="arm_link2"/>
      <origin xyz="0 0 0.15" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="3.0"/>
    </joint>
    <link name="gripper_base">
      <visual><geometry><box size="0.035 0.030 0.015"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.035 0.030 0.015"/></geometry></collision>
    </link>
    <joint name="gripper_j" type="revolute">
      <parent link="arm_link2"/><child link="gripper_base"/>
      <origin xyz="0 0 0.12" rpy="0 0 0"/><axis xyz="0 0 1"/>
      <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
    </joint>
  </xacro:macro>

  <!-- 物资舱 -->
  <xacro:macro name="supply_bay">
    <link name="supply_box">
      <visual><geometry><box size="0.20 0.30 0.12"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.20 0.30 0.12"/></geometry></collision>
      <inertial><mass value="2.0"/><inertia ixx="0.02" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/></inertial>
    </link>
    <joint name="supply_box_j" type="fixed">
      <parent link="base_link"/><child link="supply_box"/>
      <origin xyz="-0.10 0 0.12" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 路由器+天线 -->
  <xacro:macro name="router_antenna">
    <link name="router_box">
      <visual><geometry><box size="0.10 0.08 0.025"/></geometry><material name="dark"/></visual>
      <collision><geometry><box size="0.10 0.08 0.025"/></geometry></collision>
    </link>
    <joint name="router_box_j" type="fixed">
      <parent link="base_link"/><child link="router_box"/>
      <origin xyz="0.12 0 0.08" rpy="0 0 0"/>
    </joint>
    <link name="ant1"><visual><geometry><cylinder radius="0.005" length="0.12"/></geometry><material name="hub"/></visual></link>
    <joint name="ant1_j" type="fixed"><parent link="router_box"/><child link="ant1"/><origin xyz="0.035 0.025 0.075" rpy="0 0 0"/></joint>
    <link name="ant2"><visual><geometry><cylinder radius="0.005" length="0.12"/></geometry><material name="hub"/></visual></link>
    <joint name="ant2_j" type="fixed"><parent link="router_box"/><child link="ant2"/><origin xyz="0.035 -0.025 0.075" rpy="0 0 0"/></joint>
  </xacro:macro>

  <!-- LED 补光 -->
  <xacro:macro name="led_bar" params="x y z">
    <link name="led_bar">
      <visual><geometry><box size="0.010 0.065 0.008"/></geometry><material name="accent"/></visual>
    </link>
    <joint name="led_bar_j" type="fixed">
      <parent link="base_link"/><child link="led_bar"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>
</robot>

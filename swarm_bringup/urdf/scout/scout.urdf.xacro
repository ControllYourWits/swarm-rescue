<?xml version="1.0"?>
<!--
  scout.urdf.xacro — Scout 探测先遣机

  传感器: RPLidar + Livox Mid-360 + RealSense D455 + AWR1642 + UWB + IMU
  尺寸: 420×320mm, 6.5kg
  网格: linorobot2 chassis.dae + tire.dae (坐标系已对齐)
-->
<robot name="scout" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find swarm_bringup)/urdf/common/common_properties.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/chassis.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/mecanum_wheel.xacro"/>
  <xacro:include filename="$(find swarm_bringup)/urdf/common/sensors.xacro"/>

  <!-- 底盘 -->
  <xacro:chassis length="0.42" width="0.32" height="0.129" mass="6.5"
    wheel_radius="0.048" wheel_pos_z="-0.040"
    mesh_file="package://swarm_bringup/meshes/shared/chassis.dae"
    body_material="body_blue" gazebo_r="0.18" gazebo_g="0.42" gazebo_b="0.82"/>

  <!-- 麦轮 (4个) -->
  <xacro:mecanum_wheel side="front_left"  radius="0.048" width="0.028"
    pos_x="0.160" pos_y="0.140" pos_z="-0.040" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="front_right" radius="0.048" width="0.028"
    pos_x="0.160" pos_y="-0.140" pos_z="-0.040" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_left"   radius="0.048" width="0.028"
    pos_x="-0.160" pos_y="0.140" pos_z="-0.040" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>
  <xacro:mecanum_wheel side="rear_right"  radius="0.048" width="0.028"
    pos_x="-0.160" pos_y="-0.140" pos_z="-0.040" mass="0.15"
    mesh_file="package://swarm_bringup/meshes/shared/tire.dae"/>

  <!-- Scout 传感器 -->
  <xacro:lidar_2d x="0.06" y="0" z="0.20"/>
  <xacro:lidar_3d x="0.06" y="0" z="0.16"/>
  <xacro:depth_camera x="0.21" y="0" z="0.10"/>
  <xacro:radar_mmw x="0.20" y="0" z="0.07"/>
  <xacro:imu_sensor/>
  <xacro:uwb_tag x="-0.10" y="0" z="0.14"/>

  <!-- laser_link (TF 兼容) -->
  <link name="laser_link"/>
  <joint name="laser_joint" type="fixed">
    <parent link="lidar_link"/><child link="laser_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo -->
  <xacro:include filename="$(find swarm_bringup)/urdf/common/gazebo_plugins.xacro"/>
  <xacro:gazebo_mecanum namespace="scout"
    wheel_base="0.320" wheel_separation="0.280" wheel_radius="0.048"/>
</robot>

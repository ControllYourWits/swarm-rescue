<?xml version="1.0"?>
<robot name="specialist" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- ═══════════════════════════════════════════════════════════
       Specialist 作业处置机 — 高细节 URDF
       尺寸基准: 450x350mm 底盘, 8kg, 4-DOF 机械臂
       ═══════════════════════════════════════════════════════════ -->

  <xacro:property name="CL" value="0.45"/>
  <xacro:property name="CW" value="0.35"/>
  <xacro:property name="CH" value="0.20"/>
  <xacro:property name="WR" value="0.055"/>
  <xacro:property name="WW" value="0.030"/>
  <xacro:property name="WS" value="0.30"/>
  <xacro:property name="BX" value="0.170"/>
  <xacro:property name="M"  value="8.0"/>

  <!-- ── 材质 ── -->
  <material name="spec_body"><color rgba="0.22 0.48 0.92 1.0"/></material>
  <material name="spec_plate"><color rgba="0.18 0.40 0.82 1.0"/></material>
  <material name="spec_dark"><color rgba="0.06 0.06 0.08 1.0"/></material>
  <material name="spec_frame"><color rgba="0.22 0.22 0.24 1.0"/></material>
  <material name="spec_orange"><color rgba="0.92 0.52 0.12 1.0"/></material>
  <material name="spec_arm_dark"><color rgba="0.14 0.14 0.16 1.0"/></material>
  <material name="spec_arm_joint"><color rgba="0.60 0.60 0.62 1.0"/></material>
  <material name="spec_tire"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="spec_hub"><color rgba="0.52 0.52 0.55 1.0"/></material>
  <material name="spec_led_bar"><color rgba="0.95 0.92 0.80 1.0"/></material>
  <material name="spec_lens"><color rgba="0.12 0.12 0.18 1.0"/></material>
  <material name="spec_grip_pad"><color rgba="0.30 0.30 0.30 1.0"/></material>
  <material name="spec_sos"><color rgba="0.95 0.15 0.10 1.0"/></material>

  <!-- ── 底盘主体 ── -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${CH/2}" rpy="0 0 0"/>
      <geometry><box size="${CL} ${CW} ${CH}"/></geometry>
      <material name="spec_body"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${CH/2}" rpy="0 0 0"/>
      <geometry><box size="${CL} ${CW} ${CH}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${CH/2}" rpy="0 0 0"/>
      <mass value="${M}"/>
      <inertia ixx="0.12" ixy="0" ixz="0" iyy="0.18" iyz="0" izz="0.22"/>
    </inertial>
  </link>

  <!-- 侧裙 -->
  <link name="skirt_l">
    <visual><geometry><box size="${CL*0.82} 0.012 0.065"/></geometry><material name="spec_frame"/></visual>
  </link>
  <joint name="skirt_l_j" type="fixed">
    <parent link="base_link"/><child link="skirt_l"/>
    <origin xyz="0 ${CW/2+0.005} ${CH*0.32}" rpy="0 0 0"/>
  </joint>
  <link name="skirt_r">
    <visual><geometry><box size="${CL*0.82} 0.012 0.065"/></geometry><material name="spec_frame"/></visual>
  </link>
  <joint name="skirt_r_j" type="fixed">
    <parent link="base_link"/><child link="skirt_r"/>
    <origin xyz="0 ${-CW/2-0.005} ${CH*0.32}" rpy="0 0 0"/>
  </joint>

  <!-- 上层平台 -->
  <link name="top_deck">
    <visual><geometry><box size="${CL*0.88} ${CW*0.85} 0.015"/></geometry><material name="spec_plate"/></visual>
  </link>
  <joint name="top_deck_j" type="fixed">
    <parent link="base_link"/><child link="top_deck"/>
    <origin xyz="0 0 ${CH+0.008}" rpy="0 0 0"/>
  </joint>

  <!-- ── 前保险杠 ── -->
  <link name="front_bumper">
    <visual><geometry><box size="0.025 ${CW+0.02} 0.050"/></geometry><material name="spec_frame"/></visual>
  </link>
  <joint name="front_bumper_j" type="fixed">
    <parent link="base_link"/><child link="front_bumper"/>
    <origin xyz="${CL/2+0.010} 0 ${CH*0.38}" rpy="0 0 0"/>
  </joint>

  <!-- ── 后保险杠 ── -->
  <link name="rear_bumper">
    <visual><geometry><box size="0.020 ${CW*0.80} 0.040"/></geometry><material name="spec_frame"/></visual>
  </link>
  <joint name="rear_bumper_j" type="fixed">
    <parent link="base_link"/><child link="rear_bumper"/>
    <origin xyz="${-CL/2-0.008} 0 ${CH*0.35}" rpy="0 0 0"/>
  </joint>

  <!-- ── LED 补光灯条 (前部) ── -->
  <link name="led_bar_mount">
    <visual><geometry><box size="0.015 0.08 0.012"/></geometry><material name="spec_frame"/></visual>
  </link>
  <joint name="led_bar_mount_j" type="fixed">
    <parent link="base_link"/><child link="led_bar_mount"/>
    <origin xyz="${CL/2-0.01} 0 ${CH+0.006}" rpy="0 0 0"/>
  </joint>
  <!-- 主灯条 (6颗 LED 排列) -->
  <link name="led_bar">
    <visual><geometry><box size="0.010 0.065 0.008"/></geometry><material name="spec_led_bar"/></visual>
  </link>
  <joint name="led_bar_j" type="fixed">
    <parent link="led_bar_mount"/><child link="led_bar"/>
    <origin xyz="0.012 0 0" rpy="0 0 0"/>
  </joint>
  <!-- SOS 红色指示灯 (顶部) -->
  <link name="sos_light">
    <visual><geometry><cylinder radius="0.008" length="0.006"/></geometry><material name="spec_sos"/></visual>
  </link>
  <joint name="sos_light_j" type="fixed">
    <parent link="base_link"/><child link="sos_light"/>
    <origin xyz="${CL*0.15} 0 ${CH+0.003}" rpy="0 0 0"/>
  </joint>

  <!-- ── 热成像模组 (FLIR Lepton 风格) ── -->
  <link name="thermal_housing">
    <visual><geometry><box size="0.035 0.035 0.025"/></geometry><material name="spec_dark"/></visual>
  </link>
  <joint name="thermal_housing_j" type="fixed">
    <parent link="base_link"/><child link="thermal_housing"/>
    <origin xyz="${CL/2-0.02} -0.05 ${CH+0.012}" rpy="0 0 0"/>
  </joint>
  <!-- 镜头 -->
  <link name="thermal_lens">
    <visual><geometry><cylinder radius="0.012" length="0.008"/></geometry><material name="spec_lens"/></visual>
  </link>
  <joint name="thermal_lens_j" type="fixed">
    <parent link="thermal_housing"/><child link="thermal_lens"/>
    <origin xyz="0.022 0 0" rpy="0 1.5708 0"/>
  </joint>
  <!-- 镜头金属环 -->
  <link name="thermal_ring">
    <visual><geometry><cylinder radius="0.015" length="0.003"/></geometry><material name="spec_arm_joint"/></visual>
  </link>
  <joint name="thermal_ring_j" type="fixed">
    <parent link="thermal_lens"/><child link="thermal_ring"/>
    <origin xyz="0.005 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ── 4-DOF 机械臂 ── -->

  <!-- 底座旋转平台 (肩关节底座) -->
  <link name="arm_base_plate">
    <visual><geometry><cylinder radius="0.035" length="0.015"/></geometry><material name="spec_arm_dark"/></visual>
    <collision><geometry><cylinder radius="0.035" length="0.015"/></geometry></collision>
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="arm_base_plate_j" type="fixed">
    <parent link="base_link"/><child link="arm_base_plate"/>
    <origin xyz="${-CL*0.22} 0 ${CH+0.008}" rpy="0 0 0"/>
  </joint>

  <!-- J0: 底座旋转 (Yaw) -->
  <link name="arm_link0">
    <visual>
      <geometry><cylinder radius="0.028" length="0.045"/></geometry>
      <material name="spec_arm_dark"/>
    </visual>
    <collision><geometry><cylinder radius="0.028" length="0.045"/></geometry></collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_j0" type="revolute">
    <parent link="arm_base_plate"/><child link="arm_link0"/>
    <origin xyz="0 0 0.022" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.36" upper="2.36" effort="10" velocity="3.0"/>
  </joint>

  <!-- J0 旋转关节外壳 (金属环) -->
  <link name="arm_j0_ring">
    <visual><geometry><cylinder radius="0.032" length="0.010"/></geometry><material name="spec_arm_joint"/></visual>
  </link>
  <joint name="arm_j0_ring_j" type="fixed">
    <parent link="arm_link0"/><child link="arm_j0_ring"/>
    <origin xyz="0 0 -0.015" rpy="0 0 0"/>
  </joint>

  <!-- J1: 肩部俯仰 (Pitch) — 大臂 -->
  <link name="arm_link1">
    <visual>
      <geometry><box size="0.035 0.035 0.15"/></geometry>
      <material name="spec_orange"/>
    </visual>
    <collision><geometry><box size="0.035 0.035 0.15"/></geometry></collision>
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="arm_j1" type="revolute">
    <parent link="arm_link0"/><child link="arm_link1"/>
    <origin xyz="0 0 0.022" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="3.0"/>
  </joint>

  <!-- J1 关节外壳 (舵机) -->
  <link name="arm_j1_housing">
    <visual><geometry><box size="0.042 0.042 0.028"/></geometry><material name="spec_arm_joint"/></visual>
  </link>
  <joint name="arm_j1_housing_j" type="fixed">
    <parent link="arm_link1"/><child link="arm_j1_housing"/>
    <origin xyz="0 0 -0.005" rpy="0 0 0"/>
  </joint>

  <!-- J2: 肘部俯仰 (Pitch) — 小臂 -->
  <link name="arm_link2">
    <visual>
      <geometry><box size="0.028 0.028 0.12"/></geometry>
      <material name="spec_orange"/>
    </visual>
    <collision><geometry><box size="0.028 0.028 0.12"/></geometry></collision>
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_j2" type="revolute">
    <parent link="arm_link1"/><child link="arm_link2"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="3.0"/>
  </joint>

  <!-- J2 关节外壳 -->
  <link name="arm_j2_housing">
    <visual><geometry><box size="0.034 0.034 0.022"/></geometry><material name="spec_arm_joint"/></visual>
  </link>
  <joint name="arm_j2_housing_j" type="fixed">
    <parent link="arm_link2"/><child link="arm_j2_housing"/>
    <origin xyz="0 0 -0.004" rpy="0 0 0"/>
  </joint>

  <!-- J3: 腕部俯仰 (Pitch) -->
  <link name="arm_link3">
    <visual>
      <geometry><box size="0.022 0.022 0.10"/></geometry>
      <material name="spec_orange"/>
    </visual>
    <collision><geometry><box size="0.022 0.022 0.10"/></geometry></collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_j3" type="revolute">
    <parent link="arm_link2"/><child link="arm_link3"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.09" upper="2.09" effort="8" velocity="3.0"/>
  </joint>

  <!-- J3 关节外壳 -->
  <link name="arm_j3_housing">
    <visual><geometry><cylinder radius="0.015" length="0.018"/></geometry><material name="spec_arm_joint"/></visual>
  </link>
  <joint name="arm_j3_housing_j" type="fixed">
    <parent link="arm_link3"/><child link="arm_j3_housing"/>
    <origin xyz="0 0 -0.003" rpy="0 0 0"/>
  </joint>

  <!-- ── 末端夹爪 (双指平行夹爪) ── -->
  <!-- 夹爪基座 -->
  <link name="gripper_base">
    <visual><geometry><box size="0.035 0.030 0.015"/></geometry><material name="spec_arm_dark"/></visual>
    <collision><geometry><box size="0.035 0.030 0.015"/></geometry></collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="gripper_base_j" type="revolute">
    <parent link="arm_link3"/><child link="gripper_base"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
  </joint>

  <!-- 左指 -->
  <link name="grip_finger_l">
    <visual>
      <geometry><box size="0.008 0.006 0.050"/></geometry>
      <material name="spec_grip_pad"/>
    </visual>
  </link>
  <joint name="grip_finger_l_j" type="fixed">
    <parent link="gripper_base"/><child link="grip_finger_l"/>
    <origin xyz="0 0.014 0.032" rpy="0 0 0"/>
  </joint>
  <!-- 左指尖 -->
  <link name="grip_tip_l">
    <visual>
      <geometry><box size="0.010 0.004 0.015"/></geometry>
      <material name="spec_arm_joint"/>
    </visual>
  </link>
  <joint name="grip_tip_l_j" type="fixed">
    <parent link="grip_finger_l"/><child link="grip_tip_l"/>
    <origin xyz="0 0.002 0.032" rpy="0 0 0"/>
  </joint>

  <!-- 右指 -->
  <link name="grip_finger_r">
    <visual>
      <geometry><box size="0.008 0.006 0.050"/></geometry>
      <material name="spec_grip_pad"/>
    </visual>
  </link>
  <joint name="grip_finger_r_j" type="fixed">
    <parent link="gripper_base"/><child link="grip_finger_r"/>
    <origin xyz="0 -0.014 0.032" rpy="0 0 0"/>
  </joint>
  <!-- 右指尖 -->
  <link name="grip_tip_r">
    <visual>
      <geometry><box size="0.010 0.004 0.015"/></geometry>
      <material name="spec_arm_joint"/>
    </visual>
  </link>
  <joint name="grip_tip_r_j" type="fixed">
    <parent link="grip_finger_r"/><child link="grip_tip_r"/>
    <origin xyz="0 -0.002 0.032" rpy="0 0 0"/>
  </joint>

  <!-- ── 驱动轮 ── -->
  <xacro:macro name="wheel" params="name x y">
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/><child link="${name}_link"/>
      <origin xyz="${x} ${y} -${WR+0.010}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
    <link name="${name}_link">
      <visual><geometry><cylinder radius="${WR}" length="${WW}"/></geometry><material name="spec_tire"/></visual>
      <collision><geometry><cylinder radius="${WR}" length="${WW}"/></geometry></collision>
      <inertial>
        <mass value="0.18"/>
        <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00025"/>
      </inertial>
    </link>
    <link name="${name}_hub">
      <visual><geometry><cylinder radius="${WR*0.42}" length="${WW+0.004}"/></geometry><material name="spec_hub"/></visual>
    </link>
    <joint name="${name}_hub_j" type="fixed">
      <parent link="${name}_link"/><child link="${name}_hub"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <link name="${name}_arm">
      <visual><geometry><box size="0.016 0.015 ${WR*1.7}"/></geometry><material name="spec_frame"/></visual>
    </link>
    <joint name="${name}_arm_j" type="fixed">
      <parent link="base_link"/><child link="${name}_arm"/>
      <origin xyz="${x} ${y} -${WR*0.45}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="fl" x="${BX}"  y="${WS/2}"/>
  <xacro:wheel name="fr" x="${BX}"  y="${-WS/2}"/>
  <xacro:wheel name="rl" x="${-BX}" y="${WS/2}"/>
  <xacro:wheel name="rr" x="${-BX}" y="${-WS/2}"/>

  <!-- ── Gazebo 材质 & 插件 ── -->
  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="spec_tire"><material>Gazebo/Black</material></gazebo>

  <gazebo>
    <plugin name="specialist_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>specialist</namespace></ros>
      <update_rate>100</update_rate>
      <left_joint>fl_joint rl_joint</left_joint>
      <right_joint>fr_joint rr_joint</right_joint>
      <wheel_separation>${WS}</wheel_separation>
      <wheel_diameter>${2*WR}</wheel_diameter>
      <max_wheel_torque>8.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
    <plugin name="specialist_imu" filename="libgazebo_ros_imu_sensor.so">
      <ros><namespace>specialist</namespace></ros>
      <update_rate>200</update_rate>
      <body_name>base_link</body_name>
      <topic>imu/data</topic>
    </plugin>
  </gazebo>
</robot>
